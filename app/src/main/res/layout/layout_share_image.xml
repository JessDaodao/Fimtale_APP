<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="1080px"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="48px">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="600px">

        <ImageView
            android:id="@+id/shareCoverImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:orientation="horizontal"
            android:padding="24px">

            <TextView
                android:id="@+id/shareTagType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="32px"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:background="@drawable/bg_image_tag"
                android:layout_marginEnd="12px"
                android:visibility="gone" />

            <TextView
                android:id="@+id/shareTagSource"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="32px"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:background="@drawable/bg_image_tag"
                android:layout_marginEnd="12px"
                android:visibility="gone" />

            <TextView
                android:id="@+id/shareTagLength"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="32px"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:background="@drawable/bg_image_tag"
                android:layout_marginEnd="12px"
                android:visibility="gone" />

            <TextView
                android:id="@+id/shareTagRate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="32px"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:background="@drawable/bg_image_tag"
                android:visibility="gone" />

        </LinearLayout>
    </FrameLayout>

    <TextView
        android:id="@+id/shareTitleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="48px"
        android:textColor="#000000"
        android:textSize="64px"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/shareIntroText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32px"
        android:textColor="#666666"
        android:textSize="42px"
        android:lineSpacingExtra="12px"
        android:maxLines="10"
        android:ellipsize="end" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/shareTagChipGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32px"
        app:chipSpacingHorizontal="16px"
        app:chipSpacingVertical="16px" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="48px"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginEnd="32px">

            <ImageView
                android:layout_width="36px"
                android:layout_height="36px"
                android:src="@drawable/ic_word_count"
                app:tint="#999999" />

            <TextView
                android:id="@+id/shareWordCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8px"
                android:textColor="#999999"
                android:textSize="32px" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginEnd="32px">

            <ImageView
                android:layout_width="36px"
                android:layout_height="36px"
                android:src="@drawable/ic_view_count"
                app:tint="#999999" />

            <TextView
                android:id="@+id/shareViewCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8px"
                android:textColor="#999999"
                android:textSize="32px" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginEnd="32px">

            <ImageView
                android:layout_width="36px"
                android:layout_height="36px"
                android:src="@drawable/ic_comment_count"
                app:tint="#999999" />

            <TextView
                android:id="@+id/shareCommentCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8px"
                android:textColor="#999999"
                android:textSize="32px" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="36px"
                android:layout_height="36px"
                android:src="@drawable/ic_favorite"
                app:tint="#999999" />

            <TextView
                android:id="@+id/shareFavoriteCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8px"
                android:textColor="#999999"
                android:textSize="32px" />
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="96px"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="32px"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/shareLogoImage"
                android:layout_width="wrap_content"
                android:layout_height="100px"
                android:adjustViewBounds="true"
                android:layout_marginBottom="24px" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="长按或扫描二维码阅读"
                android:textColor="#acacac"
                android:textSize="36px"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <ImageView
            android:id="@+id/shareQrCodeImage"
            android:layout_width="200px"
            android:layout_height="200px" />

    </LinearLayout>

</LinearLayout>
